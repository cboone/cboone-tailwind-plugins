    "url": "git+https://github.com/cboone/cboone-tailwind-plugins.git"
  },
  "peerDependencies": {
    "tailwindcss": "^3.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
